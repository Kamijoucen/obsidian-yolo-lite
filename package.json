    "openai": "^4.91.1",
    "path-browserify": "^1.0.1",
    "proxy-agent": "^6.5.0",
    "proxy-chain": "^2.7.1",
    "proxy-from-env": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shell-env": "^4.0.1",
    "uuid": "^10.0.0",
    "vscode-diff": "^2.1.1",
    "zod": "^3.25.76"
  }
}
