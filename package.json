{
  "name": "obsidian-yolo-lite",
  "version": "1.0.0",
  "description": "Focused Obsidian agent chat with vault tools, Skills, and web search.",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n app,styles,sync -c blue,magenta,yellow \"npm:dev:app\" \"npm:styles:watch\" \"npm:dev:sync\"",
    "ob": "osascript -e 'quit app \"Obsidian\"' >/dev/null 2>&1 || true && sleep 1 && open -a Obsidian --args --remote-debugging-port=9222 && npm run dev",
    "dev:app": "node esbuild.config.mjs",
    "dev:sync": "node scripts/sync-dev-artifacts.mjs",
    "build": "tsc -noEmit -skipLibCheck && npm run styles:build && node esbuild.config.mjs production",
    "styles:build": "postcss src/styles/index.css -o styles.css",
    "styles:watch": "postcss src/styles/index.css -o styles.css -w",
    "version": "node version-bump.mjs",
    "prettier:check": "prettier --check --cache --cache-strategy content --cache-location node_modules/.cache/.prettiercache src __mocks__ eslint.config.mjs postcss.config.cjs",
    "prettier:write": "prettier --write --cache --cache-strategy content --cache-location node_modules/.cache/.prettiercache src __mocks__ eslint.config.mjs postcss.config.cjs",
    "lint": "npm run lint:check",
    "lint:check": "npm run prettier:check && eslint --cache --cache-location node_modules/.cache/.eslintcache src __mocks__",
    "lint:fix": "npm run prettier:write && eslint --cache --cache-location node_modules/.cache/.eslintcache --fix src __mocks__",
    "type:check": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsconfig.typecheck.tsbuildinfo",
    "test": "jest --maxWorkers=50%",
    "test:watch": "jest --watch",
    "test:changed": "jest -o"
  },
  "keywords": [],
  "author": "Kamijoucen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kamijoucen/obsidian-yolo-lite.git"
  },
  "bugs": {
    "url": "https://github.com/Kamijoucen/obsidian-yolo-lite/issues"
  },
  "homepage": "https://github.com/Kamijoucen/obsidian-yolo-lite#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cross-spawn": "^6.0.6",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^16.11.6",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "builtin-modules": "3.3.0",
    "concurrently": "^9.2.1",
    "esbuild": "0.17.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "obsidian": "latest",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tslib": "2.4.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "@codemirror/state": "^6.5.1",
